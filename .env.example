# ── Django core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
# Comma-separated: phishguard-tool.onrender.com,localhost
ALLOWED_HOSTS=*

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (local dev). Set to Render Postgres URL in production.
# Format: postgres://user:password@host:5432/dbname
DATABASE_URL=

# ── API Keys ──────────────────────────────────────────────────────────────────
VT_API_KEY=3910025e647744f62b57678dbbb4e74e0e4d1f8acfe0694cf648fdfef13b95bd
ABUSEIPDB_KEY=0b9f0f2f51dda82e17c5f3de326a93172639d456d9fe4678512d78bc4ac21e396eb56fdd208b1a17
GSB_API_KEY=your-google-safe-browsing-api-key
NEWS_API_KEY=6a7a3e049c674e4bb70e0f50f0ae187f

# ── Encryption (for stored API keys) ─────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from https://console.upstash.com — use the rediss:// TLS URL
REDIS_URL=rediss://your-upstash-url:6379

# ── Screenshot capture ────────────────────────────────────────────────────────
# Get free key from https://apiflash.com (500 screenshots/month)
SCREENSHOT_ENABLED=False
APIFLASH_KEY=your-apiflash-access-key

# ── Threat feeds ──────────────────────────────────────────────────────────────
# PhishTank: https://www.phishtank.com/api_register.php (leave blank = offline DB)
PHISHTANK_KEY=your-phishtank-api-key
# Shodan: https://account.shodan.io/register (free tier available)
SHODAN_API_KEY=YoPqz0zxKl9pbsc1MR8H0gG3rlGe2tfJ

# ── Email (watchlist alerts) ──────────────────────────────────────────────────
# Use console backend locally; switch to smtp for production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=PhishGuard <noreply@phishguard.app>
SITE_URL=https://phishguard-tool.onrender.com

# ── Error tracking ────────────────────────────────────────────────────────────
# Get from https://sentry.io (free tier available) — leave blank to disable
SENTRY_DSN=

# ── Logging ───────────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=WARNING
